# GitHub token used by forkable for all API calls.
# Required scopes:
#   repo               full repo access (private + public)
#   workflow           if bootstrap installs sync workflows
#   read:org           preflight policy detection
#
# For org-restricted operations the token must be SSO-authorized for that org.
GITHUB_TOKEN=

# Optional: override the GitHub API base URL (GHES, ghe.com, custom).
# Default: https://api.github.com
# GITHUB_API_URL=

# Optional: override the state directory.
# Default: OS-appropriate user state dir from env-paths.
# FORKABLE_STATE_DIR=
